# Application
APP_NAME=AI Recruiter Outreach Platform
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql://recruiter:recruiter123@postgres:5432/recruiter_db
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# AI - Grok API
GROK_API_KEY=""
GROK_MODEL=grok-4.3
GROK_BASE_URL=https://api.x.ai/v1

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_NAME=Your Name
SMTP_USE_TLS=true

# IMAP (for reply detection)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=your_gmail@gmail.com
IMAP_PASSWORD=your_app_password
IMAP_USE_SSL=true

# File Storage
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10

# Rate Limiting
EMAILS_PER_HOUR=50
EMAILS_PER_DAY=200
EMAIL_DELAY_MIN_SECONDS=30
EMAIL_DELAY_MAX_SECONDS=120

# App Base URL (for tracking pixels)
BASE_URL=http://localhost:8000

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Celery
CELERY_WORKER_CONCURRENCY=4
